# Optional API keys. The app works without them (keyless providers only).
# Add a key to automatically enable the matching provider.

OPENWEATHERMAP_API_KEY=
WEATHERAPI_API_KEY=
TOMORROW_API_KEY=
VISUALCROSSING_API_KEY=
WEERLIVE_API_KEY=

# Contact e-mail sent as User-Agent to MET Norway (required by their TOS).
CONTACT_EMAIL=info@mooisteweer.nl

# Cache time-to-live in seconds.
CACHE_TTL_SECONDS=1800
GEOCODE_CACHE_TTL_SECONDS=86400

# Per-request HTTP timeout in seconds.
HTTP_TIMEOUT=12
